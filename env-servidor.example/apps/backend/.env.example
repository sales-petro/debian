PORT=3021

SWAGGER_ENABLED=true
LOGGER_LEVEL=debug
LOGGER_LABEL=development
LOGS_DIR=../../.logs

# Postgres — copie para env-servidor/apps/backend/.env e defina a senha lá
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_NAME=hubsaas
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true
DATABASE_MIGRATIONS_RUN=true

REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# JWT e fiscal — gerar valores fortes só no .env real (env-servidor/)
AUTH_JWT_ACCESS_EXPIRES_IN=1d
AUTH_JWT_REFRESH_EXPIRES_IN=1w

# URL pública do frontend (ngrok cytoplasm ou hubswp.ddns.net)
FRONTEND_URL=https://cytoplasm-quicken-asparagus.ngrok-free.dev
SHOPEE_REVIEW_WEBHOOK_BASE_URL=https://cytoplasm-quicken-asparagus.ngrok-free.dev
SHOPEE_REVIEW_ML_REDIRECT_URI=https://cytoplasm-quicken-asparagus.ngrok-free.dev/v1/channels/oauth/mercadolivre/callback

AUTH_BOOTSTRAP_ENABLED=false
AUTH_BOOTSTRAP_AUTO_TENANT=false
